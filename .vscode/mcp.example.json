{
  // Example MCP server config for Cloudflare — copy to `.vscode/mcp.json`
  // and ensure your environment provides the required variables.
  "servers": {
    "cloudflare": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "--yes",
        "@cloudflare/mcp-server-cloudflare"
      ],
      "env": {
        "CLOUDFLARE_API_TOKEN": "${env:CLOUDFLARE_API_TOKEN}",
        "CLOUDFLARE_ACCOUNT_ID": "${env:CLOUDFLARE_ACCOUNT_ID}"
      }
    }
  }
}
