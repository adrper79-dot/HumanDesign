{
  "name": "prime-self-engine",
  "version": "0.1.0",
  "description": "Prime Self — Human Design + Astrology calculation engine",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:deterministic": "vitest run --maxWorkers=1",
    "test:guidance": "vitest run tests/guidance-regression.test.js --maxWorkers=1",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:prod:smoke": "playwright test tests/e2e/prod-smoke.spec.ts --project=chromium",
    "test:gate": "playwright test --config playwright.gate.config.ts",
    "test:setup": "node scripts/recreate-e2e-account.js",
    "test:e2e:wsl": "node scripts/run-playwright-wsl-cdp.js",
    "deploy:workers": "cd workers && npx wrangler deploy",
    "verify:prod": "node workers/verify-production.js",
    "verify:canary": "node workers/verify-canary.js",
    "verify:money": "node workers/verify-money-path.js",
    "verify:prod:gate": "node scripts/run-prod-gate.js",
    "verify:prod:gate:api": "node scripts/run-prod-gate.js --api-only",
    "deploy": "npm run deploy:workers && npm run verify:prod",
    "audit": "node scripts/run-audit.js",
    "audit:vitals": "node scripts/run-audit.js --vitals-only",
    "audit:full": "node scripts/run-audit.js --force-full",
    "issue:next": "node scripts/next-issue.js",
    "issue:list": "node scripts/next-issue.js --all",
    "issue:summary": "node scripts/next-issue.js --summary",
    "issue:resolve": "node scripts/mark-resolved.js",
    "pipeline:status": "node scripts/deploy-pipeline.js --status",
    "pipeline:next": "node scripts/deploy-pipeline.js",
    "pipeline:dry": "node scripts/deploy-pipeline.js --dry-run",
    "pipeline:validate": "node scripts/deploy-pipeline.js --validate",
    "pipeline:stage": "node scripts/deploy-stage.js",
    "docs:api": "node scripts/generate-api-docs.js",
    "docs:api:check": "node scripts/generate-api-docs.js --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^3.2.4",
    "ffmpeg-static": "^5.3.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.59.0"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0"
  }
}
