{
  "name": "prime-self-engine",
  "version": "0.1.0",
  "description": "Prime Self — Human Design + Astrology calculation engine",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:deterministic": "vitest run --maxWorkers=1",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy:workers": "cd workers && npx wrangler deploy --force",
    "verify:prod": "node workers/verify-production.js",
    "verify:canary": "node workers/verify-canary.js",
    "deploy": "npm run deploy:workers && npm run verify:prod",
    "audit": "node scripts/run-audit.js",
    "audit:vitals": "node scripts/run-audit.js --vitals-only",
    "audit:full": "node scripts/run-audit.js --force-full",
    "issue:next": "node scripts/next-issue.js",
    "issue:list": "node scripts/next-issue.js --all",
    "issue:summary": "node scripts/next-issue.js --summary",
    "issue:resolve": "node scripts/mark-resolved.js"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "ffmpeg-static": "^5.3.0",
    "sharp": "^0.34.5",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.59.0"
  }
}
