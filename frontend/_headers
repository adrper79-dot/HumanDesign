/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://js.stripe.com https://static.cloudflareinsights.com https://plausible.io; style-src 'self' 'unsafe-inline'; connect-src 'self' https://prime-self-api.adrper79.workers.dev https://api.stripe.com https://cloudflareinsights.com https://plausible.io; img-src 'self' data: blob:; media-src 'self'; font-src 'self' data:; frame-src https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(self "https://js.stripe.com")
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# GEO: AI crawler and search engine assets — long cache, indexable
/robots.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

/sitemap.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

/definitions.html
  Cache-Control: public, max-age=3600
  X-Robots-Tag: index, follow

# Admin dashboard — noindex; external JS file for CSP hardening (BL-AUDIT-H4)
/admin.html
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';

# Billing pages — never cache; inline scripts only (no external JS needed)
/billing/success.html
  Cache-Control: no-store
  X-Robots-Tag: noindex

/billing/cancel.html
  Cache-Control: no-store
  X-Robots-Tag: noindex

# Service worker must NEVER be cached — browser must always fetch fresh to detect updates
/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# Embed surface must be frameable by practitioner-owned sites.
# BL-AUDIT-H2: frame-ancestors https: allows any HTTPS site to embed. This is intentional design:
# - Product vision: practitioners embed widget on their own client-facing sites for lead generation
# - Risk: clickjacking / brand misappropriation by third parties
# - Mitigation: Referer header logged in embed handler for audit trail. Monitor CF Analytics for unexpected embedding patterns.
# - Alternative: Whitelist known domains (requires operational process and updates)
# Decision: Accept open HTTPS policy + log audit trail (2026-03-17)
/embed
  ! Content-Security-Policy
  ! X-Frame-Options
  Content-Security-Policy: default-src 'self'; script-src 'self' https://js.stripe.com https://static.cloudflareinsights.com https://plausible.io; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.stripe.com https://cloudflareinsights.com https://plausible.io; img-src 'self' data: blob:; media-src 'self'; font-src 'self' data:; frame-src https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors https:;

/embed.html
  ! Content-Security-Policy
  ! X-Frame-Options
  Content-Security-Policy: default-src 'self'; script-src 'self' https://js.stripe.com https://static.cloudflareinsights.com https://plausible.io; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.stripe.com https://cloudflareinsights.com https://plausible.io; img-src 'self' data: blob:; media-src 'self'; font-src 'self' data:; frame-src https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors https:; # BL-AUDIT-H2: See /embed route comments above

